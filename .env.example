APP_NAME=Lina
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

DB_CONNECTION=sqlite
DB_DATABASE=database/sqlite/app.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"

# Vercel Blob - required for large file uploads (reels)
# Create a blob store in Vercel dashboard and copy the token
# BLOB_READ_WRITE_TOKEN=
